@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <!-- Hero Banner -->
    <div class="p-5 mb-4 bg-light rounded-3">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold">Welcome to GameHub Store</h1>
            <p class="col-md-8 fs-4 mx-auto">Find the best deals on the latest and greatest games.</p>
            <button class="btn btn-primary btn-lg" type="button">Browse Catalog</button>
        </div>
    </div>

    <!-- Featured Games -->
    <div class="container my-5">
        <h2 class="pb-2 border-bottom">Featured Games</h2>
        <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
            <div class="col">
                <div class="p-3 border bg-light h-100">[Featured Game Placeholder]</div>
            </div>
            <div class="col">
                <div class="p-3 border bg-light h-100">[Featured Game Placeholder]</div>
            </div>
            <div class="col">
                <div class="p-3 border bg-light h-100">[Featured Game Placeholder]</div>
            </div>
        </div>
    </div>

    <!-- Trending Games -->
    <div class="container my-5">
        <h2 class="pb-2 border-bottom">Trending Games</h2>
        <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
            <div class="col">
                <div class="p-3 border bg-light h-100">[Trending Game Placeholder]</div>
            </div>
            <div class="col">
                <div class="p-3 border bg-light h-100">[Trending Game Placeholder]</div>
            </div>
            <div class="col">
                <div class="p-3 border bg-light h-100">[Trending Game Placeholder]</div>
            </div>
        </div>
    </div>

    <!-- Deals -->
    <div class="container my-5">
        <h2 class="pb-2 border-bottom">Deals</h2>
        <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
            <div class="col">
                <div class="p-3 border bg-light h-100">[Deal Placeholder]</div>
            </div>
            <div class="col">
                <div class="p-3 border bg-light h-100">[Deal Placeholder]</div>
            </div>
            <div class="col">
                <div class="p-3 border bg-light h-100">[Deal Placeholder]</div>
            </div>
        </div>
    </div>
</div>
