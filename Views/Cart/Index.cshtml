@model IEnumerable<GameHubStore.Models.Cart>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="row mt-4 mb-5">
    <div class="col-md-8">
        <h2 class="mb-4">Shopping Cart</h2>
        
        @if (!Model.Any())
        {
            <div class="alert alert-info">
                Your cart is empty. <a asp-controller="Store" asp-action="Index">Continue shopping</a>.
            </div>
        }
        else
        {
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="ps-4">Game</th>
                                    <th scope="col">Price</th>
                                    <th scope="col">Quantity</th>
                                    <th scope="col">Subtotal</th>
                                    <th scope="col" class="pe-4 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var subtotal = item.Quantity * (item.Game?.Price ?? 0);
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.Game?.ImageUrl) && item.Game?.ImageUrl != "default-game.jpg")
                                                {
                                                    <img src="~/images/games/@item.Game.ImageUrl" alt="@item.Game.Title" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-secondary rounded me-3 d-flex align-items-center justify-content-center text-white" style="width: 60px; height: 60px;">
                                                        <small>No Img</small>
                                                    </div>
                                                }
                                                <div>
                                                    <h6 class="mb-0">@item.Game?.Title</h6>
                                                    <small class="text-muted">@item.Game?.Genre?.Name</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>$@item.Game?.Price</td>
                                        <td>
                                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                                                <input type="hidden" name="cartId" value="@item.CartId" />
                                                <input type="number" name="quantity" value="@item.Quantity" class="form-control form-control-sm text-center me-2" style="width: 60px;" min="1" onchange="this.form.submit()" />
                                            </form>
                                        </td>
                                        <td class="fw-bold">$@subtotal</td>
                                        <td class="pe-4 text-end">
                                            <form asp-action="RemoveFromCart" method="post">
                                                <input type="hidden" name="cartId" value="@item.CartId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
    
    @if (Model.Any())
    {
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h4 class="card-title mb-4">Order Summary</h4>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Items (@Model.Sum(x => x.Quantity)):</span>
                        <span>$@ViewBag.CartTotal</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Estimated Tax (0%):</span>
                        <span>$0.00</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <strong class="fs-5">Total:</strong>
                        <strong class="fs-5 text-primary">$@ViewBag.CartTotal</strong>
                    </div>
                    
                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-success w-100 btn-lg">Proceed to Checkout</a>
                </div>
            </div>
        </div>
    }
</div>
