@model IEnumerable<GameHubStore.Models.Game>

@{
    ViewData["Title"] = "Games List";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Games</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Game</a>
</div>

<form asp-action="Index" method="get" class="mb-4 d-flex">
    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Search by title..." />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
</form>

<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Image</th>
                <th>Title</th>
                <th>Price</th>
                <th>Genre</th>
                <th>Release Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="~/images/games/@item.ImageUrl" alt="@item.Title" style="width: 50px; height: auto;" class="rounded" />
                    </td>
                    <td>@item.Title</td>
                    <td>$@item.Price</td>
                    <td>@item.Genre?.Name</td>
                    <td>@item.ReleaseDate.ToShortDateString()</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.GameId" class="btn btn-sm btn-warning">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.GameId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this game?');">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            @if(!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center">No games found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
